{
  "name": "bago.ph-quadstack",
  "version": "1.0.0",
  "description": "BAGO.PH — Barangay App for Garbage Operations (PH). Static HTML/CSS prototype + Express/MySQL API.",
  "homepage": "https://github.com/mikaelleon/bago.ph-quadstack#readme",
  "bugs": {
    "url": "https://github.com/mikaelleon/bago.ph-quadstack/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikaelleon/bago.ph-quadstack.git"
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "server/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "node server/index.js",
    "dev:api": "node server/index.js",
    "dev:web": "serve html --listen 5500 --no-port-switching",
    "dev:all": "concurrently --kill-others-on-fail \"npm run dev:api\" \"npm run dev:web\"",
    "start": "node server/index.js",
    "test": "node --test \"server/tests/**/*.test.js\""
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "mysql2": "^3.22.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "serve": "^14.2.6",
    "supertest": "^7.1.4"
  }
}
