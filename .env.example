# BAGO.PH API — copy to .env and adjust
PORT=3000

# MySQL (pick ONE style)
DATABASE_URL=mysql://root:@localhost:3306/bago_ph
# Or discrete vars:
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=bago_ph

# Required in production (min 16 chars). Dev falls back to a console warning if unset.
JWT_SECRET=replace-with-a-long-random-secret-key

# Comma-separated origins, or * for reflect (dev). Example:
# CORS_ORIGIN=http://127.0.0.1:5500,http://localhost:5500
